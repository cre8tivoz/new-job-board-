# Server-only Neon connection string. Never prefix this variable with VITE_.
DATABASE_URL=postgresql://replace_user:replace_password@replace_host/replace_database?sslmode=require

# Generate a unique value of at least 32 characters for every environment.
BETTER_AUTH_SECRET=replace_with_a_unique_random_value_of_at_least_32_characters
BETTER_AUTH_URL=http://localhost:3000
APP_ORIGIN=http://localhost:3000

# Local demonstration seed configuration. Use replaceable test credentials only.
ALLOW_DEMO_SEED=1
DEMO_PASSWORD=replace_with_a_local_demo_password_of_at_least_12_characters
DEMO_CANDIDATE_EMAIL=candidate.demo@cre8tiv.test
DEMO_EMPLOYER_EMAIL=employer.demo@cre8tiv.test
DEMO_ADMIN_EMAIL=admin.demo@cre8tiv.test
