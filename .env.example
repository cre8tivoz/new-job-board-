# Public Firebase web configuration. VITE_ values are intentionally bundled
# for the browser and must never contain privileged server credentials.
VITE_FIREBASE_API_KEY=replace_with_restricted_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=replace_with_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=replace_with_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=replace_with_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=replace_with_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=replace_with_firebase_web_app_id
VITE_FIREBASE_MEASUREMENT_ID=replace_with_firebase_measurement_id

# Server-only values. Never prefix these with VITE_.
FIREBASE_PROJECT_ID=replace_with_firebase_project_id
GEMINI_API_KEY=replace_with_server_only_gemini_api_key
RAPIDAPI_KEY=replace_with_server_only_rapidapi_key
APP_ORIGIN=replace_with_canonical_application_origin
PORT=replace_with_server_port
TRUST_PROXY=replace_with_0_or_1
DISABLE_HMR=replace_with_true_or_false
