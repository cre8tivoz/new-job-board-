{
  "name": "cre8tiv-job-board",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist-server/server.mjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --packages=external --outfile=dist-server/server.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:verify": "node --import tsx scripts/db/verify-migrations.ts",
    "db:seed": "node --import tsx scripts/db/seed.ts",
    "security:secrets": "node scripts/security/scan-secrets.mjs",
    "security:secrets:history": "node scripts/security/scan-secrets.mjs --history",
    "security:audit": "npm audit --audit-level=high",
    "security": "npm run security:secrets && npm run security:audit",
    "check": "npm run lint && npm run typecheck && npm run db:verify && npm test && npm run security:secrets && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    }
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-auth": "^1.6.23",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^4.22.2",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.1",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.23.1",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  }
}
