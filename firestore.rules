rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSafePublicUrl(value) {
      return value is string &&
             value.size() <= 1000 &&
             (value == '' || value.matches('^https://[^\\s]+$'));
    }

    function isValidProject(project) {
      return project is map &&
             project.keys().hasAll(['id', 'title', 'img']) &&
             project.keys().hasOnly(['id', 'title', 'img']) &&
             project.id is int && project.id >= 0 &&
             project.title is string &&
             project.title.size() > 0 && project.title.size() <= 100 &&
             project.img is string && project.img.matches('^https://[^\\s]+$') &&
             project.img.size() <= 1000;
    }

    function hasValidProjects(projects) {
      return projects is list &&
             projects.size() <= 6 &&
             (projects.size() < 1 || isValidProject(projects[0])) &&
             (projects.size() < 2 || isValidProject(projects[1])) &&
             (projects.size() < 3 || isValidProject(projects[2])) &&
             (projects.size() < 4 || isValidProject(projects[3])) &&
             (projects.size() < 5 || isValidProject(projects[4])) &&
             (projects.size() < 6 || isValidProject(projects[5]));
    }

    function isValidPassport(data, userId) {
      return data.keys().hasAll([
               'uid', 'name', 'title', 'location', 'experience', 'bio',
               'avatarUrl', 'projects', 'updatedAt'
             ]) &&
             data.keys().hasOnly([
               'uid', 'name', 'title', 'location', 'experience', 'bio',
               'avatarUrl', 'projects', 'updatedAt'
             ]) &&
             data.uid is string && data.uid == userId &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.location is string && data.location.size() <= 100 &&
             data.experience is string && data.experience.size() <= 100 &&
             data.bio is string && data.bio.size() <= 2000 &&
             isSafePublicUrl(data.avatarUrl) &&
             hasValidProjects(data.projects) &&
             data.updatedAt is timestamp && data.updatedAt == request.time;
    }

    match /passports/{userId} {
      // Passport documents contain only deliberately public profile fields.
      // Private candidate material such as CV files must live in a separate,
      // owner-only collection when persistent storage is implemented.
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidPassport(request.resource.data, userId);
      allow delete: if isOwner(userId);
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
